{
  "name": "aura-vscode",
  "displayName": "Aura",
  "description": "Joylitix Aura — Ask-mode agent (MVP track: chat + daemon)",
  "version": "0.0.0",
  "publisher": "joylitix",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCommand:aura.startSession", "onView:aura.chatView"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aura-sidebar",
          "title": "Aura",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "aura-sidebar": [
        {
          "type": "webview",
          "id": "aura.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "aura.startSession",
        "title": "Aura: Start session"
      },
      {
        "command": "aura.toggleProtocolLog",
        "title": "Aura: Toggle developer protocol log"
      }
    ],
    "configuration": {
      "title": "Aura",
      "properties": {
        "aura.developer.showProtocolLog": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, mirror daemon stdout NDJSON lines to the Aura (Protocol) output channel."
        },
        "aura.provider": {
          "type": "string",
          "enum": ["openai", "ollama"],
          "default": "openai",
          "description": "LLM backend for the daemon."
        },
        "aura.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Model id passed to the provider."
        },
        "aura.openaiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI-compatible API base URL (no trailing slash)."
        },
        "aura.ollamaBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Ollama HTTP base URL."
        }
      }
    }
  },
  "scripts": {
    "prebuild": "npm run build --workspace=@aura/agent-daemon",
    "build": "node ./scripts/compile.mjs",
    "vscode:prepublish": "npm run build",
    "compile": "npm run build"
  },
  "dependencies": {
    "@aura/protocol": "0.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "typescript": "~5.8.0"
  }
}
